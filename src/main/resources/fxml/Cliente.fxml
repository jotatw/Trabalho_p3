<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.ifg.luziania.trabalho_p3.controller.ClienteController">
   <children>
      <GridPane>
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Nome" />
            <TextField fx:id="campoNome" GridPane.columnIndex="1" />
            <TextField fx:id="campoCpf" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="campoCnh" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <TextField fx:id="campoTelefone" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <TextField fx:id="campoEmail" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label text="CPF" GridPane.rowIndex="1" />
            <Label text="CNH" GridPane.rowIndex="2" />
            <Label text="Telefone" GridPane.rowIndex="3" />
            <Label text="E-mail" GridPane.rowIndex="4" />
         </children>
      </GridPane>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#salvar" text="Salvar" />
            <Button fx:id="btnLimpar" mnemonicParsing="false" onAction="#limpar" text="Limpar" />
            <Button fx:id="btnVoltar" mnemonicParsing="false" onAction="#voltar" text="Voltar" />
         </children>
      </HBox>
      <TableView fx:id="tabelaCliente" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="colunaNome" prefWidth="75.0" text="Nome" />
          <TableColumn fx:id="colunaCpf" prefWidth="75.0" text="CPF" />
            <TableColumn fx:id="colunaCnh" prefWidth="75.0" text="CNH" />
            <TableColumn fx:id="colunaTelefone" prefWidth="75.0" text="Telefone" />
            <TableColumn fx:id="colunaEmail" prefWidth="75.0" text="E-mail" />
        </columns>
      </TableView>
   </children>
</VBox>
