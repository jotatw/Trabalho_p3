<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="VBox"
           stylesheets="@../css/estilos.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.br.ifg.luziania.trabalho_p3.controller.LoginController">
   <VBox alignment="CENTER" spacing="14" styleClass="cartao, cartao-login">
      <children>
         <Label layoutX="185.0" layoutY="-2.0" styleClass="titulo-login" text="Locadora de veiculos" />
         <Label text="Ente com seu E-mail e senha" styleClass="subtitulo-login"/>

         <TextField fx:id="campoemail" promptText="E-mail" styleClass="campo-texto" />
         <PasswordField fx:id="campoSenha" promptText="Senha" styleClass="campo-texto" />

         <Button fx:id="btnEntrar" layoutX="13.0" layoutY="164.0" mnemonicParsing="false" onAction="#fazerLogin" styleClass="btn-primario" text="Entrar" />
      </children>
   </VBox>
</StackPane>
