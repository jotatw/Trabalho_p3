<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="15" styleClass="VBox" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.ifg.luziania.trabalho_p3.controller.LoginController">
   <children>
      <Label layoutX="185.0" layoutY="-2.0" styleClass="titulo" text="Locadora de veiculos" />
      <TextField fx:id="campoemail" promptText="E-mail" styleClass="campo-texto" />
      <PasswordField fx:id="campoSenha" promptText="Senha" styleClass="campo-texto" />
      <Button fx:id="btnEntrar" layoutX="13.0" layoutY="164.0" mnemonicParsing="false" onAction="#fazerLogin" styleClass="btn-primario" text="Entrar" />
   </children>
</VBox>
