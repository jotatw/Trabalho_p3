<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0"
      stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.ifg.luziania.trabalho_p3.controller.UsuarioController">
   <children>
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Nome" />
            <Label text="E-mail" GridPane.rowIndex="1" />
            <Label text="Senha" GridPane.rowIndex="2" />
            <Label text="Perfil" GridPane.rowIndex="3" />
            <TextField fx:id="campoNome" GridPane.columnIndex="1" />
            <TextField fx:id="campoEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="campoSenha" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <ComboBox fx:id="cmbPerfil" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
      </GridPane>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#salvar" styleClass="btn-primario" text="Salvar" />
            <Button fx:id="btnLimpar" mnemonicParsing="false" onAction="#limpar" styleClass="btn-secundario" text="Limpar" />
            <Button fx:id="btnVoltar" mnemonicParsing="false" onAction="#voltar" styleClass="btn-secundario" text="Voltar" />
         </children>
      </HBox>
      <TableView fx:id="tabelaUsuario" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="tabelaNome" prefWidth="75.0" text="Nome" />
          <TableColumn fx:id="tabelaEmail" prefWidth="75.0" text="E-mail" />
            <TableColumn fx:id="tabelaPerfil" prefWidth="75.0" text="Perfil" />
        </columns>
      </TableView>
   </children>
</VBox>
